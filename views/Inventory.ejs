function populateStockSel() {
  const sel=document.getElementById('stock-mat-sel');
  const cur=sel.value;
  sel.innerHTML='<option value="">— Select material —</option>'+
    [...materials].sort((a,b)=>a.part_number.localeCompare(b.part_number))
      .map(m=>`<option value="${m.id}">${m.part_number} — ${m.name}</option>`).join('');
  if(cur) sel.value=cur;
}

function showCurrentQty() {
  const id=document.getElementById('stock-mat-sel').value;
  const m=materials.find(x=>String(x.id)===String(id));
  const panel=document.getElementById('current-qty-panel');
  if(m){document.getElementById('current-qty-val').textContent=`${m.quantity} ${m.unit}`;panel.style.display='block';}
  else panel.style.display='none';
}

async function submitStockUpdate(e) {
  e.preventDefault();
  const id   = document.getElementById('stock-mat-sel').value;
  const type = document.getElementById('stock-type').value;
  const qty  = parseFloat(document.getElementById('stock-qty').value);
  const note = document.getElementById('stock-note').value.trim();

  if(!id)         { inlineAlert('stock-alert','error','Select a material.'); return; }
  if(!qty||qty<=0){ inlineAlert('stock-alert','error','Enter a valid quantity.'); return; }

  try {
    const res = await fetch('/api/stock-logs', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ material_id:id, change_type:type, quantity_changed:qty, reference_note:note||null })
    });
    if (!res.ok) throw new Error('Stock update failed');
  } catch (err) {
    console.error(err);
    inlineAlert('stock-alert','error','Failed to update stock on server.');
    return;
  }

  inlineAlert('stock-alert','success',`Stock ${type==='IN'?'added':'removed'}: ${qty}`);
  document.getElementById('stock-qty').value='';
  document.getElementById('stock-note').value='';

  await loadMaterialsFromDB();
  await loadStockLogsFromDB();
  showCurrentQty();
}

function renderStockLog() {
  const tbody=document.getElementById('stock-log-tbody');
  document.getElementById('log-badge').textContent=stockLogs.length;
  if(!stockLogs.length){
    tbody.innerHTML='<tr><td colspan="6"><div class="empty-state" style="padding:30px"><p>No movements yet</p></div></td></tr>';
    return;
  }
  tbody.innerHTML=stockLogs.slice(0,50).map(l=>{
    const isIn=l.change_type==='IN';
    return `<tr>
      <td class="td-mono">${l.part_number}</td>
      <td><span class="badge ${isIn?'bd-in':'bd-out'}">${l.change_type}</span></td>
      <td style="font-weight:600;color:${isIn?'var(--green)':'var(--red)'}">${isIn?'+':'-'}${l.quantity_changed}</td>
      <td class="td-muted" style="font-size:12px">${l.quantity_before??'—'}→<strong>${l.quantity_after??'—'}</strong></td>
      <td class="td-muted">${l.reference_note||'—'}</td>
      <td class="td-muted" style="white-space:nowrap;font-size:11px">${fmtDT(l.date||l.created_at)}</td>
    </tr>`;
  }).join('');
}

// ──────────────────────────────────────────────────────
//  FULL INFORMATION
// ──────────────────────────────────────────────────────
async function initFullInfo() {
  document.getElementById('fi-refreshed').textContent = 'Refreshed: '+new Date().toLocaleString('en-IN');
  fi_updateSummary();
  fi_buildCatFilter();
  fi_filterMat();
  fi_filterLog();
  fi_renderCats();
  fi_renderTimeline();
  await fi_loadChallans();
}

function fi_updateSummary() {
  const low=materials.filter(m=>parseFloat(m.quantity)<=parseFloat(m.low_stock_threshold)).length;
  const val=materials.reduce((s,m)=>s+(parseFloat(m.quantity)||0)*(parseFloat(m.unit_price)||0),0);
  document.getElementById('fi-s-mat').textContent = materials.length;
  document.getElementById('fi-s-low').textContent = low;
  document.getElementById('fi-s-mov').textContent = stockLogs.length;
  document.getElementById('fi-s-val').textContent = '₹'+fmt(val,0);
}

async function fi_loadChallans() {
  try {
    const res = await fetch('/api/delivery-challans');
    const dc  = await res.json();
    document.getElementById('fi-s-dc').textContent      = dc.length;
    document.getElementById('fi-dc-badge').textContent  = dc.length;
    allChallans = dc;
    fi_renderDC(dc);
  } catch {
    document.getElementById('fi-dc-tbody').innerHTML='<tr><td colspan="8"><div class="empty-state" style="padding:24px"><p>Could not load from server</p></div></td></tr>';
  }
}

function fi_buildCatFilter() {
  const cats=[...new Set(materials.map(m=>m.category).filter(Boolean))].sort();
  const sel=document.getElementById('fi-mat-cat'); if(!sel) return;
  const cur=sel.value;
  sel.innerHTML='<option value="">All Categories</option>'+cats.map(c=>`<option>${c}</option>`).join('');
  if(cur) sel.value=cur;
}

function fi_filterMat() {
  const s  =document.getElementById('fi-mat-search').value.toLowerCase();
  const c  =document.getElementById('fi-mat-cat').value;
  const st =document.getElementById('fi-mat-stk').value;
  fiMatFiltered=materials.filter(m=>{
    const ms=!s||m.part_number.toLowerCase().includes(s)||m.name.toLowerCase().includes(s)||(m.supplier||'').toLowerCase().includes(s);
    const mc=!c||m.category===c;
    const isL=parseFloat(m.quantity)<=parseFloat(m.low_stock_threshold);
    const mst=!st||(st==='low'?isL:!isL);
    return ms&&mc&&mst;
  });
  fiMatPage=1;
  fi_renderMat();
  document.getElementById('fi-mat-badge').textContent=fiMatFiltered.length;
}

function fi_renderMat() {
  const tbody=document.getElementById('fi-mat-tbody'), pagEl=document.getElementById('fi-mat-pag'), total=fiMatFiltered.length;
  if(!total){
    tbody.innerHTML='<tr><td colspan="15"><div class="empty-state"><i class="fas fa-search"></i><p>No materials match</p></div></td></tr>';
    pagEl.style.display='none'; return;
  }
  const tp=Math.ceil(total/PER_PAGE.fi_mat);
  if(fiMatPage>tp) fiMatPage=tp;
  const s=(fiMatPage-1)*PER_PAGE.fi_mat;
  tbody.innerHTML=fiMatFiltered.slice(s,s+PER_PAGE.fi_mat).map(m=>{
    const qty=parseFloat(m.quantity), thr=parseFloat(m.low_stock_threshold);
    const isLow=qty<=thr;
    const pct=thr>0?Math.min(100,Math.round((qty/(thr*2))*100)):100;
    const barCls=isLow?'sbar-low':pct<60?'sbar-mid':'sbar-ok';
    const val=qty*(parseFloat(m.unit_price)||0);
    return `<tr style="cursor:pointer" onclick="toggleRowDetail2('${m.id}')">
      <td style="padding:8px 6px 8px 14px">
        <i id="ricon2-${m.id}" class="fas fa-chevron-right" style="font-size:10px;color:var(--text-3);transition:transform .15s"></i>
      </td>
      <td class="td-mono">${m.part_number}</td>
      <td style="font-weight:500;max-width:180px">${m.name}</td>
      <td><span class="badge bd-blue">${m.category||'—'}</span></td>
      <td class="td-muted">${m.make||'—'}</td>
      <td style="font-weight:700;color:${isLow?'var(--red)':'var(--green)'}">
        ${qty}${isLow?'<span class="badge bd-red" style="margin-left:4px;font-size:10px">LOW</span>':''}
      </td>
      <td class="td-muted">${m.unit}</td>
      <td>
        <div style="display:flex;align-items:center;gap:6px">
          <div class="sbar-wrap"><div class="sbar ${barCls}" style="width:${pct}%"></div></div>
          <span class="td-muted">${pct}%</span>
        </div>
      </td>
      <td class="td-muted">${m.unit_price?'₹'+fmt(m.unit_price,2):'—'}</td>
      <td style="font-weight:500">${val?'₹'+fmt(val,0):'—'}</td>
      <td class="td-mono" style="color:var(--text-2);font-size:11px">${m.location||'—'}</td>
      <td class="td-muted" style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${m.supplier||'—'}</td>
      <td class="td-mono" style="color:var(--text-2)">${m.hsn_code||'—'}</td>
      <td class="td-muted">${m.date_added||'—'}</td>
      <td class="td-muted" style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${m.remarks||'—'}</td>
    </tr>
    <tr id="rdetail2-${m.id}" style="display:none;background:#fafbfd">
      <td colspan="15" style="padding:12px 20px">
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px">
          ${[['Supplier',m.supplier||'—'],['Location',m.location||'—'],['Dimensions',m.dim_length?`${m.dim_length}×${m.dim_width}×${m.dim_height} ${m.dim_unit}`:'—'],
            ['Threshold',m.low_stock_threshold+' '+m.unit],['HSN',m.hsn_code||'—'],['Date Added',m.date_added||'—'],
            ['Updated',fmtDT(m.updated_at||m.created_at)],['Remarks',m.remarks||'—']].map(([l,v])=>
          `<div><div class="td-muted" style="font-size:10px;text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px">${l}</div>
               <div style="font-size:13px;font-weight:500">${v}</div></div>`).join('')}
        </div>
      </td>
    </tr>`;
  }).join('');

  if(tp<=1){pagEl.style.display='none';}
  else{
    pagEl.style.display='flex';
    document.getElementById('fi-mat-pag-info').textContent=`${s+1}–${Math.min(s+PER_PAGE.fi_mat,total)} of ${total}`;
    let b=`<button class="pag-btn ${fiMatPage===1?'disabled':''}" onclick="fiMatGo(${fiMatPage-1})">‹</button>`;
    for(let p=Math.max(1,fiMatPage-2);p<=Math.min(tp,fiMatPage+2);p++) b+=`<button class="pag-btn ${p===fiMatPage?'active':''}" onclick="fiMatGo(${p})">${p}</button>`;
    b+=`<button class="pag-btn ${fiMatPage===tp?'disabled':''}" onclick="fiMatGo(${fiMatPage+1})">›</button>`;
    document.getElementById('fi-mat-pag-btns').innerHTML=b;
  }
}

function toggleRowDetail2(id) {
  const row=document.getElementById('rdetail2-'+id), icon=document.getElementById('ricon2-'+id);
  const open=row.style.display!=='none';
  row.style.display=open?'none':'table-row';
  icon.style.transform=open?'rotate(0)':'rotate(90deg)';
}

function fiMatGo(p) { fiMatPage=p; fi_renderMat(); }

function fi_filterLog() {
  const s =document.getElementById('fi-log-search').value.toLowerCase();
  const t =document.getElementById('fi-log-type').value;
  const pd=document.getElementById('fi-log-period').value;
  const now=new Date();
  fiLogFiltered=stockLogs.filter(l=>{
    const ms=!s||(l.part_number||'').toLowerCase().includes(s)||(l.material_name||'').toLowerCase().includes(s)||(l.reference_note||'').toLowerCase().includes(s);
    const mt=!t||l.change_type===t;
    let md=true;
    if(pd){
      const dt=new Date(l.date||l.created_at);
      if(pd==='today') md=dt.toDateString()===now.toDateString();
      else if(pd==='week') md=(now-dt)<=7*864e5;
      else if(pd==='month') md=dt.getMonth()===now.getMonth()&&dt.getFullYear()===now.getFullYear();
    }
    return ms&&mt&&md;
  });
  fiLogPage=1; fi_renderLog();
  document.getElementById('fi-log-badge').textContent=fiLogFiltered.length;
}

function fi_renderLog() {
  const tbody=document.getElementById('fi-log-tbody'), pagEl=document.getElementById('fi-log-pag'), total=fiLogFiltered.length;
  if(!total){
    tbody.innerHTML='<tr><td colspan="10"><div class="empty-state"><i class="fas fa-exchange-alt"></i><p>No movements match</p></div></td></tr>';
    pagEl.style.display='none'; return;
  }
  const tp=Math.ceil(total/PER_PAGE.fi_log);
  if(fiLogPage>tp) fiLogPage=tp;
  const s=(fiLogPage-1)*PER_PAGE.fi_log;
  tbody.innerHTML=fiLogFiltered.slice(s,s+PER_PAGE.fi_log).map((l,i)=>{
    const isIn=l.change_type==='IN';
    return `<tr>
      <td class="td-muted">${s+i+1}</td>
      <td class="td-muted" style="white-space:nowrap;font-size:11.5px">${fmtDT(l.date||l.created_at)}</td>
      <td class="td-mono">${l.part_number||'—'}</td>
      <td style="font-weight:500;max-width:150px">${l.material_name||'—'}</td>
      <td><span class="badge ${isIn?'bd-in':'bd-out'}">${l.change_type}</span></td>
      <td style="font-weight:700;color:${isIn?'var(--green)':'var(--red)'}">${isIn?'+':'-'}${l.quantity_changed}</td>
      <td class="td-muted">${l.quantity_before??'—'}</td>
      <td style="font-weight:600">${l.quantity_after??'—'}</td>
      <td class="td-muted">${l.unit||'—'}</td>
      <td class="td-muted">${l.reference_note||'—'}</td>
    </tr>`;
  }).join('');

  if(tp<=1){pagEl.style.display='none';}
  else{
    pagEl.style.display='flex';
    document.getElementById('fi-log-pag-info').textContent=`${s+1}–${Math.min(s+PER_PAGE.fi_log,total)} of ${total}`;
    let b=`<button class="pag-btn ${fiLogPage===1?'disabled':''}" onclick="fiLogGo(${fiLogPage-1})">‹</button>`;
    for(let p=Math.max(1,fiLogPage-2);p<=Math.min(tp,fiLogPage+2);p++) b+=`<button class="pag-btn ${p===fiLogPage?'active':''}" onclick="fiLogGo(${p})">${p}</button>`;
    b+=`<button class="pag-btn ${fiLogPage===tp?'disabled':''}" onclick="fiLogGo(${fiLogPage+1})">›</button>`;
    document.getElementById('fi-log-pag-btns').innerHTML=b;
  }
}

function fiLogGo(p) { fiLogPage=p; fi_renderLog(); }

function fi_filterDC() {
  const s =document.getElementById('fi-dc-search').value.toLowerCase();
  const st=document.getElementById('fi-dc-status').value;
  fi_renderDC(allChallans.filter(c=>{
    const ms=!s||c.challan_no.toLowerCase().includes(s)||(c.consignee_name||'').toLowerCase().includes(s);
    if(!st) return ms;
    const {status}=challanStatus(c);
    return ms&&status===st;
  }));
}

function fi_renderDC(list) {
  document.getElementById('fi-dc-badge').textContent=list.length;
  const tbody=document.getElementById('fi-dc-tbody');
  if(!list.length){tbody.innerHTML='<tr><td colspan="8"><div class="empty-state" style="padding:24px"><i class="fas fa-truck"></i><p>No challans match</p></div></td></tr>';return;}
  tbody.innerHTML=list.map(c=>{
    const {days,status}=challanStatus(c);
    const dayStr=days===null?'—':days<0?`<span style="color:var(--red);font-weight:700">${days}d</span>`:days<=5?`<span style="color:var(--red);font-weight:700">${days}d</span>`:days<=10?`<span style="color:var(--amber);font-weight:600">${days}d</span>`:`<span style="color:var(--green)">${days}d</span>`;
    const stBadge=status==='Overdue'||status==='Due Soon'?'bd-red':status==='Approaching'?'bd-amber':'bd-green';
    return `<tr>
      <td class="td-mono">${c.challan_no}</td>
      <td class="td-muted">${new Date(c.challan_date).toLocaleDateString('en-IN')}</td>
      <td style="font-weight:500">${c.consignee_name}</td>
      <td class="td-muted" style="font-size:12px">${c.requester}</td>
      <td><span class="badge bd-gray">${c.dc_type}</span></td>
      <td class="td-muted">${c.expiry_date?new Date(c.expiry_date).toLocaleDateString('en-IN'):'—'}</td>
      <td>${dayStr}</td>
      <td><span class="badge ${stBadge}">${status}</span></td>
    </tr>`;
  }).join('');
}

function fi_renderCats() {
  const tbody=document.getElementById('fi-cat-tbody');
  const total=materials.length||1;
  const catMap={};
  materials.forEach(m=>{
    const cat=m.category||'Uncategorized';
    if(!catMap[cat]) catMap[cat]={count:0,qty:0,value:0,low:0,suppliers:{}};
    catMap[cat].count++;
    catMap[cat].qty  +=parseFloat(m.quantity)||0;
    catMap[cat].value+=(parseFloat(m.quantity)||0)*(parseFloat(m.unit_price)||0);
    if(parseFloat(m.quantity)<=parseFloat(m.low_stock_threshold)) catMap[cat].low++;
    if(m.supplier) catMap[cat].suppliers[m.supplier]=(catMap[cat].suppliers[m.supplier]||0)+1;
  });
  const sorted=Object.entries(catMap).sort((a,b)=>b[1].count-a[1].count);
  if(!sorted.length){tbody.innerHTML='<tr><td colspan="7"><div class="empty-state" style="padding:24px"><p>No data</p></div></td></tr>';return;}
  tbody.innerHTML=sorted.map(([cat,d])=>{
    const pct=Math.round((d.count/total)*100);
    const top=Object.entries(d.suppliers).sort((a,b)=>b[1]-a[1])[0]?.[0]||'—';
    const lowBadge=d.low?`<span class="badge bd-red">${d.low} low</span>`:`<span class="badge bd-green">All ok</span>`;
    return `<tr>
      <td><span class="badge bd-blue">${cat}</span></td>
      <td style="font-weight:600">${d.count}</td>
      <td style="font-weight:500">${fmt(d.qty,1)}</td>
      <td>${lowBadge}</td>
      <td style="font-weight:500">${d.value?'₹'+fmt(d.value,0):'—'}</td>
      <td class="td-muted">${top}</td>
      <td>
        <div style="display:flex;align-items:center;gap:7px">
          <div class="sbar-wrap" style="width:80px"><div class="sbar sbar-ok" style="width:${pct}%"></div></div>
          <span class="td-muted">${pct}%</span>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function fi_renderTimeline() {
  const el=document.getElementById('fi-timeline');
  const logs=stockLogs.slice(0,25);
  if(!logs.length){el.innerHTML='<div class="empty-state"><i class="fas fa-history"></i><p>No activity yet</p></div>';return;}
  el.innerHTML=logs.map(l=>{
    const isIn=l.change_type==='IN';
    return `<div class="tl-item">
      <div class="tl-dot ${isIn?'in':'out'}"><i class="fas ${isIn?'fa-arrow-down':'fa-arrow-up'}" style="font-size:11px"></i></div>
      <div class="tl-body">
        <div class="tl-title">
          <span class="td-mono">${l.part_number}</span> — ${l.material_name}
          <span style="color:${isIn?'var(--green)':'var(--red)'};font-weight:700;margin-left:6px">${isIn?'+':'-'}${l.quantity_changed} ${l.unit}</span>
        </div>
        <div class="tl-sub">
          ${isIn?'Stock received':'Stock issued'}
          ${l.reference_note?'· Ref: <strong>'+l.reference_note+'</strong>':''}
          · <span title="${new Date(l.date||l.created_at).toLocaleString('en-IN')}">${timeAgo(l.date||l.created_at)}</span>
        </div>
      </div>
    </div>`;
  }).join('');
}

function fi_toggle(bodyId, btn) {
  const body=document.getElementById(bodyId);
  const icon=btn.querySelector('i');
  const collapsed=body.classList.contains('collapsed');
  body.classList.toggle('collapsed',!collapsed);
  icon.className=collapsed?'fas fa-chevron-up':'fas fa-chevron-down';
}

function fi_expandAll() {
  ['fi-mat-body','fi-log-body','fi-dc-body','fi-cat-body','fi-tl-body'].forEach(id=>{
    const el=document.getElementById(id); if(!el) return;
    el.classList.remove('collapsed');
    const btn=el.closest('.card')?.querySelector('.collapse-btn i');
    if(btn) btn.className='fas fa-chevron-up';
  });
}

function fi_collapseAll() {
  ['fi-mat-body','fi-log-body','fi-dc-body','fi-cat-body','fi-tl-body'].forEach(id=>{
    const el=document.getElementById(id); if(!el) return;
    el.classList.add('collapsed');
    const btn=el.closest('.card')?.querySelector('.collapse-btn i');
    if(btn) btn.className='fas fa-chevron-down';
  });
}

function fi_exportCSV() {
  let csv='MATERIALS\n';
  csv+='Part Number,Name,Category,Make,Quantity,Unit,Low Threshold,Unit Price,Total Value,Supplier,Location,HSN,Date,Remarks\n';
  materials.forEach(m=>{
    const v=(parseFloat(m.quantity)||0)*(parseFloat(m.unit_price)||0);
    csv+=[m.part_number,m.name,m.category,m.make,m.quantity,m.unit,m.low_stock_threshold,
      m.unit_price,v.toFixed(2),m.supplier,m.location,m.hsn_code,m.date_added,m.remarks]
      .map(x=>`"${(x||'').toString().replace(/"/g,'""')}"`).join(',')+'\n';
  });
  csv+='\nSTOCK MOVEMENTS\n';
  csv+='Date,Part Number,Material,Type,Qty Changed,Before,After,Unit,Reference\n';
  stockLogs.forEach(l=>{
    csv+=[new Date(l.date||l.created_at).toLocaleString('en-IN'),l.part_number,l.material_name,
      l.change_type,l.quantity_changed,l.quantity_before,l.quantity_after,l.unit,l.reference_note]
      .map(x=>`"${(x||'').toString().replace(/"/g,'""')}"`).join(',')+'\n';
  });
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download=`full-report-${new Date().toISOString().split('T')[0]}.csv`;
  a.click();
}

// ──────────────────────────────────────────────────────
//  INIT
// ──────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', async () => {
  const email = 'inventory@kietsindia.com';
  document.getElementById('ua-email').textContent = email;
  document.getElementById('ua-text').textContent  = email.slice(0,2).toUpperCase();

  // Load from DB on startup
  await loadMaterialsFromDB();
  await loadStockLogsFromDB();

  setupAutocomplete('po-input-store','po-hidden-store','po-suggestions-store');
  setupAutocomplete('po-input-local','po-hidden-local','po-suggestions-local');

  handleFormSubmit('store-form','/submit-inventory','Store entry submitted successfully!');
  handleFormSubmit('local-form','/submit-inventory_local','Local purchase submitted successfully!');

  document.getElementById('m-date').value = new Date().toISOString().split('T')[0];

  setupDragScroll('dc-table-wrap');

  ['edit-modal','del-modal','detail-modal','dc-items-modal'].forEach(id=>{
    document.getElementById(id)?.addEventListener('click', function(e){
      if(e.target===this) this.classList.remove('open');
    });
  });

  refreshMatStats();
  buildMatCatFilter();
});
</script>
