function buildMatCatFilter() {
  const cats = [...new Set(materials.map(m=>m.category).filter(Boolean))].sort();
  ['mat-cat-filter','fi-mat-cat'].forEach(id=>{
    const sel=document.getElementById(id); if(!sel) return;
    const cur=sel.value;
    sel.innerHTML='<option value="">All Categories</option>'+cats.map(c=>`<option>${c}</option>`).join('');
    if(cur) sel.value=cur;
  });
}

function filterMaterials() {
  const s  = document.getElementById('mat-search').value.toLowerCase();
  const c  = document.getElementById('mat-cat-filter').value;
  const st = document.getElementById('mat-stock-filter').value;
  filteredMats = materials.filter(m=>{
    const ms = !s||m.part_number.toLowerCase().includes(s)||m.name.toLowerCase().includes(s)||(m.make||'').toLowerCase().includes(s);
    const mc = !c||m.category===c;
    const ml = parseFloat(m.quantity)<=parseFloat(m.low_stock_threshold);
    const mst= !st||(st==='low'?ml:!ml);
    return ms&&mc&&mst;
  });
  matPage=1;
  renderMatTable();
  document.getElementById('mat-count-badge').textContent = filteredMats.length;
}

function renderMatTable() {
  const tbody=document.getElementById('mat-tbody');
  const pagEl=document.getElementById('mat-pag');
  const total=filteredMats.length;

  if(!total) {
    tbody.innerHTML=`<tr><td colspan="12"><div class="empty-state"><i class="fas fa-search"></i><h3>${materials.length?'No results':'No materials yet'}</h3><p>${materials.length?'Adjust filters':'Add your first material above'}</p></div></td></tr>`;
    pagEl.style.display='none'; return;
  }

  const tp=Math.ceil(total/PER_PAGE.mat);
  if(matPage>tp) matPage=tp;
  const s=(matPage-1)*PER_PAGE.mat;
  const page=filteredMats.slice(s,s+PER_PAGE.mat);

  tbody.innerHTML=page.map(m=>{
    const qty=parseFloat(m.quantity), thr=parseFloat(m.low_stock_threshold);
    const isLow=qty<=thr;
    const pct=thr>0?Math.min(100,Math.round((qty/(thr*2))*100)):100;
    const barCls=isLow?'sbar-low':pct<60?'sbar-mid':'sbar-ok';
    const val=(qty*(parseFloat(m.unit_price)||0));
    return `<tr>
      <td style="padding:8px 6px 8px 14px">
        <i class="fas fa-chevron-right" id="ricon-${m.id}" style="font-size:10px;color:var(--text-3);cursor:pointer;transition:transform .15s"
           onclick="toggleRowDetail('${m.id}')"></i>
      </td>
      <td class="td-mono" style="cursor:pointer" onclick="openDetailModal('${m.id}')">${m.part_number}</td>
      <td style="font-weight:500;cursor:pointer" onclick="openDetailModal('${m.id}')">${m.name}</td>
      <td><span class="badge bd-blue">${m.category||'—'}</span></td>
      <td class="td-muted">${m.make||'—'}</td>
      <td style="font-weight:700;color:${isLow?'var(--red)':'var(--green)'}">
        ${qty}${isLow?'<span class="badge bd-red" style="margin-left:4px;font-size:10px">LOW</span>':''}
      </td>
      <td class="td-muted">${m.unit}</td>
      <td>
        <div style="display:flex;align-items:center;gap:7px">
          <div class="sbar-wrap"><div class="sbar ${barCls}" style="width:${pct}%"></div></div>
          <span class="td-muted">${pct}%</span>
        </div>
      </td>
      <td class="td-muted">${m.unit_price?'₹'+fmt(m.unit_price,2):'—'}</td>
      <td style="font-weight:500">${val?'₹'+fmt(val,0):'—'}</td>
      <td class="td-mono" style="color:var(--text-2);font-size:11px">${m.location||'—'}</td>
      <td>
        <div style="display:flex;gap:5px">
          <button class="btn btn-sm btn-secondary" onclick="openDetailModal('${m.id}')"><i class="fas fa-eye"></i></button>
          <button class="btn btn-sm btn-secondary" onclick="openEditModal('${m.id}')"><i class="fas fa-edit"></i></button>
          <button class="btn btn-sm btn-danger"    onclick="openDelModal('${m.id}')"><i class="fas fa-trash"></i></button>
        </div>
      </td>
    </tr>
    <tr id="rdetail-${m.id}" style="display:none;background:#fafbfd">
      <td colspan="12" style="padding:12px 20px">
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px">
          ${[['Supplier',m.supplier||'—'],['Location',m.location||'—'],['HSN Code',m.hsn_code||'—'],
             ['Date Added',m.date_added||'—'],['Dimensions',m.dim_length?`${m.dim_length}×${m.dim_width}×${m.dim_height} ${m.dim_unit}`:'—'],
             ['Threshold',m.low_stock_threshold+' '+m.unit],
             ['Remarks',m.remarks||'—'],['Updated',fmtDT(m.updated_at||m.created_at)]].map(([l,v])=>
          `<div><div class="td-muted" style="font-size:10px;text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px">${l}</div>
               <div style="font-size:13px;font-weight:500">${v}</div></div>`).join('')}
        </div>
      </td>
    </tr>`;
  }).join('');

  if(tp<=1){pagEl.style.display='none';}
  else{
    pagEl.style.display='flex';
    document.getElementById('mat-pag-info').textContent=`Showing ${s+1}–${Math.min(s+PER_PAGE.mat,total)} of ${total}`;
    let b=`<button class="pag-btn ${matPage===1?'disabled':''}" onclick="matGo(${matPage-1})">‹</button>`;
    for(let p=Math.max(1,matPage-2);p<=Math.min(tp,matPage+2);p++) b+=`<button class="pag-btn ${p===matPage?'active':''}" onclick="matGo(${p})">${p}</button>`;
    b+=`<button class="pag-btn ${matPage===tp?'disabled':''}" onclick="matGo(${matPage+1})">›</button>`;
    document.getElementById('mat-pag-btns').innerHTML=b;
  }
}

function toggleRowDetail(id) {
  const row=document.getElementById('rdetail-'+id), icon=document.getElementById('ricon-'+id);
  const open=row.style.display!=='none';
  row.style.display=open?'none':'table-row';
  icon.style.transform=open?'rotate(0)':'rotate(90deg)';
  icon.style.color=open?'var(--text-3)':'var(--blue)';
}

function matGo(p) { matPage=p; renderMatTable(); }

function refreshMatStats() {
  const low=materials.filter(m=>parseFloat(m.quantity)<=parseFloat(m.low_stock_threshold)).length;
  const val=materials.reduce((s,m)=>s+(parseFloat(m.quantity)||0)*(parseFloat(m.unit_price)||0),0);
  const cats=[...new Set(materials.map(m=>m.category).filter(Boolean))].length;
  document.getElementById('st-total').textContent = materials.length;
  document.getElementById('st-low').textContent   = low;
  document.getElementById('st-ok').textContent    = materials.length-low;
  document.getElementById('st-cats').textContent  = cats;
  document.getElementById('st-val').textContent   = '₹'+fmt(val,0);
}

function exportMatCSV() {
  const hdrs=['Part Number','Name','Category','Make','Quantity','Unit','Low Threshold','Unit Price','Total Value','Supplier','Location','HSN','Date','Remarks'];
  const rows=materials.map(m=>[m.part_number,m.name,m.category,m.make,m.quantity,m.unit,m.low_stock_threshold,m.unit_price,
    (parseFloat(m.quantity)||0)*(parseFloat(m.unit_price)||0),m.supplier,m.location,m.hsn_code,m.date_added,m.remarks]
    .map(v=>`"${(v||'').toString().replace(/"/g,'""')}"`));
  const csv=[hdrs.join(','),...rows.map(r=>r.join(','))].join('\n');
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download=`materials-${new Date().toISOString().split('T')[0]}.csv`;
  a.click();
}

