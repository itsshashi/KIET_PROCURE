<!-- ═══════════════════════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════════════════════ -->
<script>
'use strict';

// ──────────────────────────────────────────────────────
//  CONSTANTS & STATE
// ──────────────────────────────────────────────────────
const PER_PAGE = { mat:15, fi_mat:15, fi_log:20 };

let materials  = [];
let stockLogs  = [];
let allChallans = [];

let matPage = 1, filteredMats = [];
let fiMatPage = 1, fiMatFiltered = [];
let fiLogPage = 1, fiLogFiltered = [];

const TAB_META = {
  'store-management': { title:'Store Management',  sub:'Enter inventory details for store management' },
  'local-purchase':   { title:'Local Purchase',    sub:'Record locally purchased materials' },
  'delivery-challan': { title:'Delivery Challan',  sub:'View challans and return deadlines' },
  'materials':        { title:'Materials Entry',   sub:'Add and manage inventory materials' },
  'full-info':        { title:'Full Information',  sub:'Comprehensive view of all inventory data' },
};

// ──────────────────────────────────────────────────────
//  DB LOADERS  ← replaces seedDemo + localStorage
// ──────────────────────────────────────────────────────
async function loadMaterialsFromDB() {
  try {
    const res = await fetch('/api/materials');
    if (!res.ok) throw new Error('Failed to load materials');
    materials = await res.json();
  } catch (err) {
    console.error(err);
    toast('error', 'Load Failed', 'Could not load materials from server.');
    materials = [];
  }
  refreshMatStats();
  buildMatCatFilter();
  filterMaterials();
  populateStockSel();
}

async function loadStockLogsFromDB() {
  try {
    const res = await fetch('/api/stock-logs');
    if (!res.ok) throw new Error('Failed to load stock logs');
    stockLogs = await res.json();
  } catch (err) {
    console.error(err);
    stockLogs = [];
  }
  renderStockLog();
}

// ──────────────────────────────────────────────────────
//  HELPERS
// ──────────────────────────────────────────────────────
function genId()    { return Date.now().toString(36) + Math.random().toString(36).slice(2,7); }
function fmt(n,d=0) { return parseFloat(n||0).toLocaleString('en-IN',{maximumFractionDigits:d}); }
function fmtDT(iso) {
  const d=new Date(iso);
  return `${d.getDate().toString().padStart(2,'0')} ${d.toLocaleString('en',{month:'short'})} ${d.getFullYear()}, ${d.getHours().toString().padStart(2,'0')}:${d.getMinutes().toString().padStart(2,'0')}`;
}
function timeAgo(iso) {
  const s=Math.floor((Date.now()-new Date(iso))/1000);
  if(s<60) return 'just now';
  if(s<3600) return Math.floor(s/60)+'m ago';
  if(s<86400) return Math.floor(s/3600)+'h ago';
  return Math.floor(s/86400)+'d ago';
}

// ──────────────────────────────────────────────────────
//  TAB SWITCHING
// ──────────────────────────────────────────────────────
function switchTab(name, el) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.sb-item[data-tab]').forEach(i => i.classList.remove('active'));

  const panel = document.getElementById(name);
  if (panel) panel.classList.add('active');

  const item = el || document.querySelector(`[data-tab="${name}"]`);
  if (item) item.classList.add('active');

  const meta = TAB_META[name] || {};
  document.getElementById('topbar-title').textContent = meta.title || name;
  document.getElementById('topbar-sub').textContent   = meta.sub   || '';

  if (name === 'delivery-challan') loadChallans();
  if (name === 'materials')        { refreshMatStats(); buildMatCatFilter(); filterMaterials(); populateStockSel(); renderStockLog(); }
  if (name === 'full-info')        initFullInfo();
}

function switchInner(id, el) {
  document.querySelectorAll('.inner-tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.inner-tab').forEach(t => t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  el.classList.add('active');
  if (id === 'mat-list')  { buildMatCatFilter(); filterMaterials(); }
  if (id === 'mat-stock') { populateStockSel(); renderStockLog(); }
}

// ──────────────────────────────────────────────────────
//  TOAST / ALERTS
// ──────────────────────────────────────────────────────
function toast(type, title, msg) {
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `
    <div class="toast-icon"><i class="fas fa-${type==='success'?'check':'times'}"></i></div>
    <div><div class="toast-title">${title}</div>${msg?`<div class="toast-msg">${msg}</div>`:''}</div>`;
  document.getElementById('toast-wrap').appendChild(el);
  setTimeout(() => el.remove(), 3500);
}

function inlineAlert(id, type, msg) {
  const colors = { success:'#ecfdf5,#059669,#6ee7b7', error:'#fef2f2,#dc2626,#fca5a5' };
  const [bg,color,border] = colors[type]?.split(',') || ['#eff6ff','#2563eb','#93c5fd'];
  document.getElementById(id).innerHTML = `
    <div style="background:${bg};color:${color};border:1px solid ${border};border-radius:var(--radius);padding:10px 14px;font-size:13px;margin-bottom:14px;display:flex;align-items:center;gap:8px">
      <i class="fas fa-${type==='success'?'check-circle':'exclamation-circle'}"></i>${msg}
    </div>`;
  if (type==='success') setTimeout(()=>document.getElementById(id).innerHTML='', 4000);
}

// ──────────────────────────────────────────────────────
//  PO AUTOCOMPLETE
// ──────────────────────────────────────────────────────
function setupAutocomplete(inputId, hiddenId, suggestId) {
  const input   = document.getElementById(inputId);
  const hidden  = document.getElementById(hiddenId);
  const box     = document.getElementById(suggestId);
  if (!input) return;

  let timer, ctrl;
  input.addEventListener('input', function() {
    clearTimeout(timer);
    const val = this.value.trim();
    if (!val) { box.style.display='none'; return; }
    timer = setTimeout(async () => {
      try {
        if (ctrl) ctrl.abort();
        ctrl = new AbortController();
        const res    = await fetch(`/api/inventory-orders?search=${encodeURIComponent(val)}`, { signal:ctrl.signal });
        const orders = await res.json();
        box.innerHTML = '';
        if (!orders.length) { box.style.display='none'; return; }
        orders.forEach(o => {
          const item = document.createElement('div');
          item.className = 'ac-item';
          item.innerHTML = `<strong>${o.po_number}</strong><small>${o.project} | ${o.supplier}</small>`;
          item.onclick = () => {
            input.value  = `${o.po_number} — ${o.project}`;
            hidden.value = o.id;
            box.style.display = 'none';
          };
          box.appendChild(item);
        });
        box.style.display = 'block';
      } catch(e) { if(e.name!=='AbortError') console.error(e); }
    }, 300);
  });
  document.addEventListener('click', e => { if(!input.contains(e.target)) box.style.display='none'; });
}

// ──────────────────────────────────────────────────────
//  GRN GENERATION
// ──────────────────────────────────────────────────────
async function generateGRN(type) {
  const hiddenId = type === 'store' ? 'po-hidden-store' : 'po-hidden-local';
  const grnId    = type === 'store' ? 'grn_store'       : 'grn_local';
  const orderId  = document.getElementById(hiddenId).value;
  if (!orderId) { toast('error','Select Order','Please select a purchase order first.'); return; }
  try {
    const endpoint = type === 'store' ? '/api/generate-grn' : '/api/generate-grn-local';
    const res  = await fetch(endpoint, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({order_id:orderId}) });
    if (!res.ok) throw new Error();
    const data = await res.json();
    document.getElementById(grnId).value = data.grn;
    toast('success','GRN Generated', data.grn);
  } catch { toast('error','Failed','Could not generate GRN.'); }
}

// ──────────────────────────────────────────────────────
//  STORE / LOCAL FORM SUBMIT
// ──────────────────────────────────────────────────────
async function handleFormSubmit(formId, url, successMsg) {
  const form = document.getElementById(formId);
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    try {
      const res = await fetch(url, { method:'POST', body:new FormData(this) });
      if (!res.ok) throw new Error();
      toast('success','Success', successMsg);
      this.reset();
    } catch { toast('error','Failed','Submission failed. Please try again.'); }
  });
}

// ──────────────────────────────────────────────────────
//  DELIVERY CHALLANS
// ──────────────────────────────────────────────────────
async function loadChallans() {
  try {
    const res   = await fetch('/api/delivery-challans');
    allChallans = await res.json();
    document.getElementById('dc-count-badge').textContent = allChallans.length;
    renderChallansTable(allChallans);
  } catch {
    document.getElementById('dc-tbody').innerHTML = `<tr><td colspan="9"><div class="empty-state"><i class="fas fa-exclamation-triangle"></i><p>Could not load challans from server</p></div></td></tr>`;
  }
}

function filterChallans() {
  const s  = document.getElementById('dc-search').value.toLowerCase();
  const st = document.getElementById('dc-status-filter').value;
  renderChallansTable(allChallans.filter(c => {
    const ms = !s || c.challan_no.toLowerCase().includes(s) || (c.consignee_name||'').toLowerCase().includes(s);
    if (!st) return ms;
    const days = c.expiry_date ? Math.ceil((new Date(c.expiry_date)-new Date())/864e5) : null;
    const status = days===null?'Active':days<0?'Overdue':days<=5?'Due Soon':days<=10?'Approaching':'Active';
    return ms && status===st;
  }));
}

function challanStatus(c) {
  if (!c.expiry_date) return { days:null, status:'Active' };
  const days = Math.ceil((new Date(c.expiry_date)-new Date())/864e5);
  return { days, status: days<0?'Overdue':days<=5?'Due Soon':days<=10?'Approaching':'Active' };
}

function renderChallansTable(list) {
  const tbody = document.getElementById('dc-tbody');
  if (!list.length) {
    tbody.innerHTML = `<tr><td colspan="9"><div class="empty-state"><i class="fas fa-truck"></i><h3>No challans found</h3></div></td></tr>`;
    return;
  }
  tbody.innerHTML = list.map(c => {
    const {days, status} = challanStatus(c);
    const dayStr = days===null ? '—'
      : days<0   ? `<span style="color:var(--red);font-weight:700">${days}d (overdue)</span>`
      : days<=5  ? `<span style="color:var(--red);font-weight:700">${days}d</span>`
      : days<=10 ? `<span style="color:var(--amber);font-weight:600">${days}d</span>`
      :            `<span style="color:var(--green)">${days}d</span>`;
    const stBadge = status==='Overdue'?'bd-red':status==='Due Soon'?'bd-red':status==='Approaching'?'bd-amber':'bd-green';
    return `<tr>
      <td class="td-mono">${c.challan_no}</td>
      <td class="td-muted">${new Date(c.challan_date).toLocaleDateString('en-IN')}</td>
      <td style="font-weight:500">${c.consignee_name}</td>
      <td class="td-muted">${c.requester}</td>
      <td><span class="badge bd-gray">${c.dc_type}</span></td>
      <td class="td-muted">${c.expiry_date?new Date(c.expiry_date).toLocaleDateString('en-IN'):'—'}</td>
      <td>${dayStr}</td>
      <td><span class="badge ${stBadge}">${status}</span></td>
      <td>
        <div style="display:flex;gap:6px">
          <button class="btn btn-sm btn-secondary" onclick="viewDCItems(${c.id},'${c.challan_no}')"><i class="fas fa-eye"></i></button>
          <button class="btn btn-sm btn-danger" onclick="closeDC(${c.id},this)">Close</button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

async function viewDCItems(id, challanNo) {
  document.getElementById('dc-modal-sub').textContent = `Challan No: ${challanNo}`;
  document.getElementById('dc-items-content').innerHTML = '<p style="padding:20px;color:var(--text-3)">Loading…</p>';
  document.getElementById('dc-items-modal').classList.add('open');
  try {
