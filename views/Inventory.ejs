async function submitMaterial(e) {
  e.preventDefault();

  const el = id => document.getElementById(id);

  const part = el('m-part').value.trim().toUpperCase();
  const name = el('m-name').value.trim();
  const cat  = el('m-cat').value;
  const qty  = parseFloat(el('m-qty').value);
  const unit = el('m-unit').value;

  if (!part || !name || !cat || isNaN(qty) || qty <= 0 || !unit) {
    inlineAlert('mat-add-alert','error','Please fill all required fields.');
    return;
  }

  const mat = {
    part_number: part,
    name,
    category: cat,
    make: el('m-make').value.trim(),
    dim_length: parseFloat(el('m-len').value) || null,
    dim_width:  parseFloat(el('m-wid').value) || null,
    dim_height: parseFloat(el('m-hei').value) || null,
    dim_unit: el('m-dim-unit').value,
    hsn_code: el('m-hsn').value.trim(),
    quantity: qty,
    unit,
    low_stock_threshold: parseFloat(el('m-threshold').value) || 10,
    unit_price: parseFloat(el('m-price').value) || 0,
    supplier: el('m-supplier').value.trim(),
    location: el('m-loc').value.trim(),
    date_added: el('m-date').value || new Date().toISOString().split('T')[0],
    remarks: el('m-remarks').value.trim(),
  };

  const res = await fetch('/api/add_materials', {
  method: 'POST',
  headers: {'Content-Type':'application/json'},
  body: JSON.stringify(mat)
});

if (!res.ok) {
  const errData = await res.json();                          // ← read server message
  inlineAlert('mat-add-alert','error', errData.error || 'Database save failed.');
  return;
}


  inlineAlert('mat-add-alert','success',`"${name}" added to database.`);
  el('mat-add-form').reset();
  el('m-date').value = new Date().toISOString().split('T')[0];

  await loadMaterialsFromDB();
  await loadStockLogsFromDB();
  toast('success','Material Added', `${part} — ${name}`);
}

