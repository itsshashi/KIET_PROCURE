function closeEditModal() { document.getElementById('edit-modal').classList.remove('open'); }

async function submitEdit(e) {
  e.preventDefault();
  const id   = document.getElementById('edit-id').value;
  const part = document.getElementById('e-part').value.trim().toUpperCase();

  // check duplicate part number (excluding self)
  if (materials.find(m=>m.part_number===part && String(m.id)!==String(id))) {
    inlineAlert('edit-alert','error',`Part number "${part}" already used.`); return;
  }

  const payload = {
    part_number:         part,
    name:                document.getElementById('e-name').value.trim(),
    category:            document.getElementById('e-cat').value,
    make:                document.getElementById('e-make').value.trim(),
    quantity:            parseFloat(document.getElementById('e-qty').value),
    unit:                document.getElementById('e-unit').value,
    low_stock_threshold: parseFloat(document.getElementById('e-threshold').value)||10,
    unit_price:          parseFloat(document.getElementById('e-price').value)||0,
    supplier:            document.getElementById('e-supplier').value.trim(),
    location:            document.getElementById('e-loc').value.trim(),
    remarks:             document.getElementById('e-remarks').value.trim(),
  };

  try {
    const res = await fetch(`/api/materials/${id}`, {
      method: 'PUT',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify(payload)
    });
    if (!res.ok) throw new Error('Update failed');
  } catch (err) {
    console.error(err);
    inlineAlert('edit-alert','error','Could not save changes. Please try again.');
    return;
  }

  closeEditModal();
  await loadMaterialsFromDB();
  await loadStockLogsFromDB();
  toast('success','Updated', payload.name);
}

let deleteTarget = null;
function openDelModal(id) {
  const m=materials.find(x=>x.id===id); if(!m) return;
  deleteTarget = id;
  document.getElementById('del-mat-name').textContent = `"${m.name}"`;
