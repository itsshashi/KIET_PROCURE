    if (!items.length) {
      document.getElementById('dc-items-content').innerHTML = '<p style="padding:20px;color:var(--text-3)">No items found.</p>';
      return;
    }
    document.getElementById('dc-items-content').innerHTML = `<table>
      <thead><tr><th>Part No</th><th>Description</th><th>HSN</th><th>Qty</th><th>Unit</th><th>Remarks</th></tr></thead>
      <tbody>${items.map(i=>`<tr>
        <td class="td-mono">${i.part_no||''}</td>
        <td>${i.description||''}</td>
        <td>${i.hsn||''}</td>
        <td>${i.quantity||''}</td>
        <td>${i.unit||''}</td>
        <td class="td-muted">${i.remarks||''}</td>
