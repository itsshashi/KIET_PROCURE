function closeItemsPModal() {
  console.log("Closing items modal");
    document.getElementById("editItemsModal").classList.remove("show");
}
async function savePoeItems(id) {

  const rows = document.querySelectorAll("#editItemsTableBody .item-row");

  const updatedItems = Array.from(rows).map(row => {
    const cells = row.querySelectorAll("td");

    const qty = parseFloat(cells[2].querySelector("input").value) || 0;
    const price = parseFloat(cells[3].querySelector("input").value) || 0;
    const gst = parseFloat(cells[4].querySelector("input").value) || 0;
    const discount = parseFloat(cells[5].querySelector("input").value) || 0;

    const baseAmount = qty * price;
    const afterDiscount = baseAmount * (1 - discount / 100);
    const finalAmount = afterDiscount * (1 + gst / 100);

    return {
      part_no: cells[0].textContent.trim(),
      description: cells[1].querySelector("textarea").value.trim(),
      quantity: qty,
      unit_price: price,
      gst: gst,
      discount: discount,
      total_amount: parseFloat(finalAmount.toFixed(2))
    };
  });

  try {
    const res = await fetch(`/api/update_po_items/${id}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ items: updatedItems })
    });

    if (res.ok) {
      alert("Items updated successfully!");
      closeItemsPModal();
    } else {
      alert("Failed to update items.");
    }
  } catch (error) {
    console.error("Error updating items:", error);
    alert("An error occurred while updating items.");
  }
}
</script>


