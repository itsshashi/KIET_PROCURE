function filterApprovalRequests() {

    const input = document.getElementById("approvalSearchInput");
    const tbody = document.getElementById("approvalRequestsBody");

    if (!input || !tbody) return;

    const filter = input.value.toLowerCase();
    const rows = tbody.getElementsByTagName("tr");

    for (let i = 0; i < rows.length; i++) {

        const cells = rows[i].getElementsByTagName("td");

        const project_code = cells[2]?.innerText.toLowerCase() || "";
        const raiser = cells[5]?.innerText.toLowerCase() || "";

        rows[i].style.display =
            project_code.includes(filter) || raiser.includes(filter)
                ? ""
                : "none";
    }
}





async function filterDcApprovalRequests() {

    const input = document.getElementById("dcApprovalSearchInput");
    if (!input) {
        console.error("Search input not found");
        return;
    }

    const table = document.getElementById("approvaldcRequestsDcBody");
    if (!table) {
        console.error("Table approvaldcRequestsDcBody not found");
        return;
    }

    const filter = input.value.toLowerCase();
    const tr = table.getElementsByTagName("tr");

    for (let i = 1; i < tr.length; i++) {

        const tdDcNumber = tr[i].getElementsByTagName("td")[1];
        const tdConsignee = tr[i].getElementsByTagName("td")[5];

        if (tdDcNumber && tdConsignee) {

            const dcNumberText = tdDcNumber.textContent.toLowerCase();
            const consigneeText = tdConsignee.textContent.toLowerCase();

            tr[i].style.display =
                dcNumberText.includes(filter) || consigneeText.includes(filter)
                    ? ""
                    : "none";
        }
    }
}


async function viewDCItems(id) {

  const modal = document.getElementById("dcItemsModal");
  const tbody = document.getElementById("dcItemsBody");


  modal.style.display = "flex";
  tbody.innerHTML = `
    <tr>
      <td colspan="6" style="text-align:center; padding:20px;">
        Loading...
      </td>
    </tr>
  `;
  try {

    const res = await fetch(`/api/delivery-challans/items/${id}`);
    const data = await res.json();

    const tbody = document.getElementById("dcItemsBody");
    tbody.innerHTML = "";

    if (!data.length) {
      tbody.innerHTML = `
        <tr>
          <td colspan="6" style="text-align:center;padding:20px;">
            No items found for this DC
          </td>
        </tr>
      `;
      return;
    }

    data.forEach(item => {
      tbody.innerHTML += `
        <tr>
          <td style="padding:10px;border-right:1px solid #EBF4F6;border-bottom:0.5px solid #EBF4F6">${item.part_no}</td>
