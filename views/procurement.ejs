                 transition:0.2s;"
          onfocus="this.style.borderColor='#0d6efd'; this.style.boxShadow='0 0 0 2px rgba(13,110,253,0.15)'"
          onblur="this.style.borderColor='#ced4da'; this.style.boxShadow='none'">
      </td>

      <td style="padding:8px;">
        <input type="number" value="${item.quantity}"
          style="width:70px; text-align:center; padding:6px;
                 border:1px solid #ced4da; border-radius:6px;
                 transition:0.2s;"
          onfocus="this.style.borderColor='#0d6efd'; this.style.boxShadow='0 0 0 2px rgba(13,110,253,0.15)'"
          onblur="this.style.borderColor='#ced4da'; this.style.boxShadow='none'">
      </td>

      <td style="padding:8px;">
        <input type="number" value="${item.unit_price}"
          style="width:120px; text-align:center; padding:6px;
                 border:1px solid #ced4da; border-radius:6px;
                 transition:0.2s;"
          onfocus="this.style.borderColor='#0d6efd'; this.style.boxShadow='0 0 0 2px rgba(13,110,253,0.15)'"
