    <style>
/* Layout Container */
.action-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px; /* Space between View icon and buttons */
}

.button-group {
    display: flex;
    gap: 8px; /* Space between Approve and Reject buttons */
}

/* Base Button Styling */
.btn-action {
    border: none;
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: background 0.2s, transform 0.1s;
}

.btn-action:active {
    transform: translateY(1px);
}

/* Specific Button Colors */
.btn-approve {
    background-color: #27ae60;
    color: white;
}

.btn-approve:hover {
    background-color: #219150;
}

.btn-reject {
    background-color: #e74c3c;
    color: white;
}

.btn-reject:hover {
    background-color: #c0392b;
}

/* View Icon Styling */
.view-icon {
    color: #7f8c8d;
    cursor: pointer;
    font-size: 18px;
    transition: color 0.2s;
}

.view-icon:hover {
    color: #3498db;
}

/* Verified Badge (Status after action) */
.verified-badge {
    color: #27ae60;
    background: #eafaf1;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: bold;
    border: 1px solid #27ae60;
}



















     
