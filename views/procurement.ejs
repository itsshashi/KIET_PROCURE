          <td style="padding:10px;border-right:1px solid #EBF4F6;border-bottom:0.5px solid #EBF4F6">${item.unit}</td>
          <td style="padding:10px;border-right:1px solid #EBF4F6;border-bottom:0.5px solid #EBF4F6">${item.remarks}</td>
        </tr>
      `;
    });

    document.getElementById("dcItemsModal").style.display = "flex";
    

  } catch (error) {
    console.error("Failed to load DC items:", error);
    alert("Failed to load DC items. Please try again.");
  }
}

