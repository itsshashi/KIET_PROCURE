<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Raise Ticket</title>
    <style>
        form {
            max-width: 600px;
            margin: 0 auto;
        }
        .form-group {
            margin-bottom: 15px;
        }
        label {
            display: block;
            margin-bottom: 5px;
        }
        input[type="text"],
        textarea {
            width: 100%;
            padding: 8px;
            box-sizing: border-box;
        }
        button {
            padding: 10px 20px;
            background-color: #007bff;
            color: white;
            border: none;
            cursor: pointer;
        }
         button:hover {
            background-color: #0056b3;
        }

            .container {
                max-width: 800px;
                margin: 0 auto;
                padding: 20px;
            }
            h1 {
                text-align: center;
                margin-bottom: 30px;
            }
            input[type="file"] {
                margin-top: 10px;
            }
            span {
                display: block;
                margin-top: 5px;
                font-size: 0.2em;
                color: #666;
            }
            body {
                font-family: Arial, sans-serif;
                background-color: #f8f9fa;
                color: #333;
            }
    </style>

</head>

<body>
    <div class="container">
        <h1>Raise a Ticket</h1>
        <form action="/raise-ticket" method="POST">
            <div class="form-group
">
                <label for="subject">Subject *</label>
                <input type="text" class="form-control" id="subject" name="subject" required>
            </div>
            <div class="form-group">
                <label for="description">Description *</label>
                <textarea class="form-control" id="description" name="description" rows="5" required></textarea>
            
            
                <label for="upload photo"> Upload</label>
             <input type="file" name="ticketImage" id="ticketImage" required>
             <span style="font-size:5px">Upload a photo related to the ticket</span>
        </div>
            <button type="submit" class="btn btn-primary">Submit Ticket</button>
        <!--insert photo of that ticket -->
       
        </form>
    </div>

</html>